import React, { useState, useEffect } from 'react';
import { 
  Building2, 
  Globe, 
  Loader2, 
  Layout, 
  Download,
  Search,
  ChevronRight,
  ChevronLeft,
  Sparkles,
  Presentation,
  FileDown,
  AlertCircle,
  Rocket,
  TrendingUp,
  Target,
  Users,
  CheckCircle2,
  Lightbulb,
  MessageSquare,
  Wand2,
  Mail,
  Copy
} from 'lucide-react';

// API設定（環境により自動供給）
const apiKey = ""; 

export default function App() {
  const [companyName, setCompanyName] = useState('');
  const [companyUrl, setCompanyUrl] = useState('');
  const [proposalType, setProposalType] = useState('new'); // 'new' or 'existing'
  const [tone, setTone] = useState('standard'); // 'standard', 'aggressive', 'trust', 'logical'
  const [isGenerating, setIsGenerating] = useState(false);
  const [progress, setProgress] = useState('');
  const [proposal, setProposal] = useState(null);
  const [currentSlide, setCurrentSlide] = useState(0);
  const [error, setError] = useState(null);
  const [isExporting, setIsExporting] = useState(false);
  const [isRewriting, setIsRewriting] = useState(false);
  const [emailDraft, setEmailDraft] = useState('');
  const [showEmailModal, setShowEmailModal] = useState(false);

  // PowerPoint生成ライブラリの読み込み
  useEffect(() => {
    const script = document.createElement('script');
    script.src = "https://cdn.jsdelivr.net/gh/gitbrent/pptxgenjs@3.12.0/dist/pptxgen.bundle.js";
    script.async = true;
    document.body.appendChild(script);
  }, []);

  // 指数バックオフ付きのリトライ機能
  const fetchWithRetry = async (url, options, retries = 5) => {
    let lastError;
    for (let i = 0; i < retries; i++) {
      try {
        const response = await fetch(url, options);
        const data = await response.json();
        if (response.ok) return data;
        lastError = data.error?.message || `Status ${response.status}`;
        if (response.status !== 429 && response.status < 500) throw new Error(String(lastError));
      } catch (e) {
        lastError = e instanceof Error ? e.message : String(e);
        if (i === retries - 1) throw new Error(lastError);
      }
      await new Promise(res => setTimeout(res, Math.pow(2, i) * 1000));
    }
    throw new Error(String(lastError || 'API接続エラー'));
  };

  const safeParseJson = (text) => {
    try {
      const cleanJson = text.replace(/^```json\n?/, '').replace(/\n?```$/, '').trim();
      const parsed = JSON.parse(cleanJson);
      if (!parsed.slides || !Array.isArray(parsed.slides)) {
        parsed.slides = [];
      }
      return parsed;
    } catch (e) {
      console.error("Parse error:", e);
      throw new Error("AIデータの解析に失敗しました。もう一度お試しください。");
    }
  };

  // 提案書の生成
  const generateProposal = async () => {
    if (!companyName) return;
    setIsGenerating(true);
    setProposal(null);
    setError(null);
    setCurrentSlide(0);
    setEmailDraft('');

    try {
      setProgress('ターゲット企業の事業内容をリサーチ中...');
      const searchResult = await fetchWithRetry(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ parts: [{ text: `企業名: ${companyName}\nURL: ${companyUrl}\nこの不動産会社の強み、対応エリア、注力事業を調査してください。「イエウール」を提案するための課題を特定してください。` }] }],
            tools: [{ google_search: {} }]
          })
        }
      );

      const researchText = searchResult.candidates?.[0]?.content?.parts?.[0]?.text || "";

      setProgress(`${proposalType === 'new' ? '新規導入' : '運用拡大'}のストーリーを構築中...`);
      const toneContext = {
        standard: "標準的でプロフェッショナル",
        aggressive: "機会損失を強調する熱意あるトーン",
        trust: "誠実さと信頼重視",
        logical: "数字とデータを重視する論理的トーン"
      }[tone];

      const systemContext = proposalType === 'new' 
        ? "イエウール導入のメリット（集客DX、媒介獲得増）を強調してください。" 
        : "運用拡大（エリア拡大、種別追加）のメリットをデータに基づき提案してください。";

      const structResult = await fetchWithRetry(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ 
              parts: [{ text: `リサーチ結果: ${researchText}\n上記を基にイエウール提案資料を作成してください。ステータス: ${proposalType === 'new' ? '新規' : '既存'}。${systemContext}\nトーン: ${toneContext}\n\nJSON形式で出力：\n{\n "title": "提案タイトル",\n "slides": [\n  { "title": "見出し", "points": ["箇条書き1", "箇条書き2"], "insight": "一言インサイト", "iconType": "rocket/target/chart/users" }\n ]\n}` }] 
            }],
            generationConfig: {
              responseMimeType: "application/json",
              responseSchema: {
                type: "OBJECT",
                properties: {
                  title: { type: "STRING" },
                  slides: {
                    type: "ARRAY",
                    items: {
                      type: "OBJECT",
                      properties: {
                        title: { type: "STRING" },
                        points: { type: "ARRAY", items: { type: "STRING" } },
                        insight: { type: "STRING" },
                        iconType: { type: "STRING" }
                      },
                      required: ["title", "points", "insight", "iconType"]
                    }
                  }
                },
                required: ["title", "slides"]
              }
            }
          })
        }
      );

      const proposalData = safeParseJson(structResult.candidates?.[0]?.content?.parts?.[0]?.text || "{}");

      setProgress('カバー画像を生成中...');
      const imageResult = await fetchWithRetry(
        `https://generativelanguage.googleapis.com/v1beta/models/imagen-4.0-generate-001:predict?key=${apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            instances: [{ prompt: `Modern real estate business infographic style, lime green and white theme, clean professional growth concept, 3D render style` }],
            parameters: { sampleCount: 1 }
          })
        }
      );

      const coverImg = imageResult.predictions?.[0]?.bytesBase64Encoded 
        ? `data:image/png;base64,${imageResult.predictions[0].bytesBase64Encoded}`
        : "https://images.unsplash.com/photo-1560518883-ce09059eeffa?auto=format&fit=crop&w=800&q=80";

      setProposal({
        ...proposalData,
        coverImage: coverImg,
        researchSummary: researchText
      });
    } catch (err) {
      setError(err instanceof Error ? err.message : String(err));
    } finally {
      setIsGenerating(false);
    }
  };

  // スライドの再書き出し（ブラッシュアップ）
  const rewriteSlide = async () => {
    if (!proposal || currentSlide === 0) return;
    setIsRewriting(true);
    try {
      const slideIndex = currentSlide - 1;
      const currentSlideData = proposal.slides[slideIndex];
      
      const result = await fetchWithRetry(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ 
              parts: [{ text: `以下のスライドをさらに説得力のある表現に書き直してください。トーン: ${tone}\nタイトル: ${currentSlideData.title}\n内容: ${currentSlideData.points?.join(', ')}\nインサイト: ${currentSlideData.insight}\n\nJSON形式: { "title": "新タイトル", "points": ["新ポイント1", "新ポイント2"], "insight": "新インサイト" }` }] 
            }],
            generationConfig: { responseMimeType: "application/json" }
          })
        }
      );

      const newData = safeParseJson(result.candidates?.[0]?.content?.parts?.[0]?.text || "{}");
      const updatedSlides = [...proposal.slides];
      updatedSlides[slideIndex] = { ...currentSlideData, ...newData };
      setProposal({ ...proposal, slides: updatedSlides });
    } catch (err) {
      setError("ブラッシュアップに失敗しました。");
    } finally {
      setIsRewriting(false);
    }
  };

  // メール文面の生成
  const generateEmail = async () => {
    if (!proposal) return;
    setShowEmailModal(true);
    if (emailDraft) return;

    try {
      const result = await fetchWithRetry(
        `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`,
        {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            contents: [{ 
              parts: [{ text: `以下の提案内容に基づき、${companyName}様へのフォローアップメールを作成してください。トーン: ${tone}\n提案タイトル: ${proposal.title}` }] 
            }]
          })
        }
      );
      setEmailDraft(result.candidates?.[0]?.content?.parts?.[0]?.text || "生成失敗。");
    } catch (err) {
      setEmailDraft("エラーが発生しました。");
    }
  };

  const handleExport = async () => {
    if (!proposal || !window.PptxGenJS) return;
    setIsExporting(true);
    try {
      const pptx = new window.PptxGenJS();
      pptx.layout = 'LAYOUT_WIDE';

      // 表紙
      const titleSlide = pptx.addSlide();
      titleSlide.background = { color: "F0F9F0" };
      titleSlide.addText(proposal.title || "イエウール提案資料", { x: 0.5, y: 3, w: '60%', fontSize: 36, bold: true, color: "27AE60" });
      if (proposal.coverImage && proposal.coverImage.startsWith('data:')) {
        titleSlide.addImage({ data: proposal.coverImage, x: '65%', y: '10%', w: '30%', h: '80%' });
      }

      // 各スライド
      proposal.slides?.forEach(s => {
        const slide = pptx.addSlide();
        slide.addText(s.title || "見出し", { x: 0.5, y: 0.5, fontSize: 28, bold: true, color: "27AE60" });
        slide.addText((s.points || []).join('\n\n'), { x: 0.5, y: 1.5, w: '90%', fontSize: 16 });
        slide.addShape(pptx.ShapeType.rect, { x: 0.5, y: 5.5, w: '90%', h: 1, fill: { color: "E8F5E9" } });
        slide.addText(`Insight: ${s.insight || ""}`, { x: 0.7, y: 5.7, w: '85%', fontSize: 14, italic: true, color: "1B5E20" });
      });

      await pptx.writeFile({ fileName: `${companyName}_提案書.pptx` });
    } catch (e) {
      setError("書き出しに失敗しました。");
    } finally {
      setIsExporting(false);
    }
  };

  const getIcon = (type) => {
    switch(type) {
      case 'rocket': return <Rocket className="text-emerald-500" />;
      case 'target': return <Target className="text-emerald-500" />;
      case 'chart': return <TrendingUp className="text-emerald-500" />;
      case 'users': return <Users className="text-emerald-500" />;
      default: return <CheckCircle2 className="text-emerald-500" />;
    }
  };

  const copyToClipboard = (text) => {
    const el = document.createElement('textarea');
    el.value = text;
    document.body.appendChild(el);
    el.select();
    document.execCommand('copy');
    document.body.removeChild(el);
  };

  return (
    <div className="min-h-screen bg-[#F0F4F0] font-sans text-slate-800 p-4 md:p-8">
      <div className="max-w-7xl mx-auto">
        <header className="bg-white rounded-3xl p-6 shadow-sm mb-8 flex flex-col lg:flex-row justify-between items-center gap-6">
          <div className="flex items-center gap-3">
            <div className="bg-[#2ECC71] p-3 rounded-2xl shadow-lg shadow-emerald-200">
              <Presentation className="text-white w-8 h-8" />
            </div>
            <div>
              <h1 className="text-2xl font-black text-slate-900 tracking-tight">イエウール提案ジェネレーター</h1>
              <p className="text-sm text-emerald-600 font-bold italic underline decoration-2">Speee Sales AI Tool</p>
            </div>
          </div>

          <div className="flex flex-wrap items-center gap-4">
            <div className="flex items-center gap-2 bg-slate-50 p-1 rounded-xl border border-slate-100">
              <span className="text-[10px] font-black text-slate-400 px-2 uppercase tracking-widest">Tone ✨</span>
              <select 
                value={tone}
                onChange={(e) => setTone(e.target.value)}
                className="bg-transparent text-sm font-bold text-emerald-600 outline-none cursor-pointer px-2"
              >
                <option value="standard">標準</option>
                <option value="aggressive">アグレッシブ</option>
                <option value="trust">信頼重視</option>
                <option value="logical">論理重視</option>
              </select>
            </div>

            <div className="bg-slate-100 p-1 rounded-xl flex">
              <button 
                onClick={() => setProposalType('new')}
                className={`px-4 py-2 rounded-lg text-sm font-bold transition-all ${proposalType === 'new' ? 'bg-white text-emerald-600 shadow-sm' : 'text-slate-400'}`}
              >
                新規
              </button>
              <button 
                onClick={() => setProposalType('existing')}
                className={`px-4 py-2 rounded-lg text-sm font-bold transition-all ${proposalType === 'existing' ? 'bg-white text-emerald-600 shadow-sm' : 'text-slate-400'}`}
              >
                既存
              </button>
            </div>

            <div className="flex gap-2">
              <input 
                type="text" placeholder="企業名を入力" 
                className="bg-slate-50 border-none rounded-xl px-4 py-2 text-sm focus:ring-2 focus:ring-emerald-400 outline-none w-48"
                value={companyName} onChange={e => setCompanyName(e.target.value)}
              />
              <button 
                onClick={generateProposal} disabled={isGenerating || !companyName}
                className="bg-[#2ECC71] hover:bg-[#27AE60] text-white px-6 py-2 rounded-xl font-black flex items-center gap-2 transition-all shadow-md active:scale-95 disabled:opacity-50"
              >
                {isGenerating ? <Loader2 className="w-4 h-4 animate-spin" /> : <Sparkles className="w-4 h-4" />}
                作成
              </button>
            </div>
          </div>
        </header>

        {error && (
          <div className="bg-red-50 text-red-600 p-4 rounded-2xl mb-8 flex items-center gap-3 border border-red-100">
            <AlertCircle className="w-5 h-5 shrink-0" />
            <span className="font-bold">{error}</span>
          </div>
        )}

        {isGenerating ? (
          <div className="flex flex-col items-center justify-center py-32 bg-white rounded-[40px] shadow-inner border-4 border-white">
            <div className="relative">
              <div className="w-24 h-24 border-8 border-emerald-100 border-t-emerald-500 rounded-full animate-spin"></div>
              <Rocket className="absolute inset-0 m-auto w-8 h-8 text-emerald-500 animate-bounce" />
            </div>
            <p className="mt-8 text-2xl font-black text-slate-800">{progress}</p>
            <p className="text-slate-400 mt-2">最強の提案書を構築しています...</p>
          </div>
        ) : proposal ? (
          <div className="grid lg:grid-cols-12 gap-8">
            <div className="lg:col-span-3 space-y-4">
              <div className="bg-white p-6 rounded-[32px] shadow-sm">
                <p className="text-[10px] font-black text-emerald-400 uppercase tracking-[0.2em] mb-4">Structure</p>
                <div className="space-y-2">
                  <button onClick={() => setCurrentSlide(0)} className={`w-full text-left px-4 py-3 rounded-2xl text-sm font-bold transition-all ${currentSlide === 0 ? 'bg-emerald-500 text-white shadow-lg' : 'hover:bg-slate-50'}`}>
                    0. 表紙
                  </button>
                  {proposal?.slides?.map((s, idx) => (
                    <button key={idx} onClick={() => setCurrentSlide(idx+1)} className={`w-full text-left px-4 py-3 rounded-2xl text-sm font-bold transition-all ${currentSlide === idx+1 ? 'bg-emerald-500 text-white shadow-lg' : 'hover:bg-slate-50'}`}>
                      {idx+1}. {s.title}
                    </button>
                  ))}
                </div>
              </div>

              <div className="space-y-3">
                <button 
                  onClick={generateEmail}
                  className="w-full bg-emerald-50 text-emerald-600 py-4 rounded-[32px] font-black flex items-center justify-center gap-3 hover:bg-emerald-100 transition-all border-2 border-emerald-100"
                >
                  <Mail className="w-5 h-5" />
                  メール文面作成 ✨
                </button>
                <button 
                  onClick={handleExport} disabled={isExporting}
                  className="w-full bg-[#F1C40F] hover:bg-[#D4AC0D] text-white py-4 rounded-[32px] font-black flex items-center justify-center gap-3 shadow-xl shadow-yellow-100 transition-all active:scale-95"
                >
                  {isExporting ? <Loader2 className="animate-spin" /> : <FileDown />}
                  PPTXファイル出力
                </button>
              </div>
            </div>

            <div className="lg:col-span-9">
              <div className="bg-white rounded-[48px] shadow-2xl overflow-hidden min-h-[600px] flex flex-col border-8 border-white group relative">
                
                {currentSlide !== 0 && proposal?.slides?.[currentSlide-1] && (
                  <button 
                    onClick={rewriteSlide}
                    disabled={isRewriting}
                    className="absolute top-6 right-20 z-10 bg-white/80 backdrop-blur-md text-emerald-600 px-4 py-2 rounded-full text-xs font-black shadow-lg border border-emerald-100 flex items-center gap-2 hover:bg-emerald-500 hover:text-white transition-all disabled:opacity-50"
                  >
                    {isRewriting ? <Loader2 className="w-3 h-3 animate-spin" /> : <Wand2 className="w-3 h-3" />}
                    さらにブラッシュアップ ✨
                  </button>
                )}

                <div className="flex-1 p-12 relative overflow-hidden">
                  <div className="absolute top-[-10%] right-[-10%] w-64 h-64 bg-emerald-50 rounded-full blur-3xl opacity-60"></div>
                  <div className="absolute bottom-[-10%] left-[-10%] w-80 h-80 bg-yellow-50 rounded-full blur-3xl opacity-60"></div>

                  {currentSlide === 0 ? (
                    <div className="relative h-full flex flex-col lg:flex-row items-center gap-12">
                      <div className="flex-1 space-y-8">
                        <span className="bg-[#2ECC71] text-white px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-widest">Exclusive Proposal</span>
                        <h2 className="text-5xl font-black text-slate-800 leading-tight">
                          {proposal.title}
                        </h2>
                        <div className="flex items-center gap-4 text-slate-400">
                          <Building2 className="w-6 h-6" />
                          <span className="text-xl font-bold">{companyName} 様</span>
                        </div>
                      </div>
                      <div className="flex-1">
                        <img src={proposal.coverImage} className="rounded-[40px] shadow-2xl rotate-3 hover:rotate-0 transition-transform duration-500 aspect-video object-cover w-full" alt="Cover" />
                      </div>
                    </div>
                  ) : (
                    proposal?.slides?.[currentSlide-1] && (
                      <div className="relative h-full flex flex-col">
                        <div className="flex items-center gap-4 mb-10">
                          <div className="bg-emerald-100 p-4 rounded-3xl">
                            {getIcon(proposal.slides[currentSlide-1].iconType)}
                          </div>
                          <h2 className="text-4xl font-black text-slate-800">
                            {proposal.slides[currentSlide-1].title}
                          </h2>
                        </div>

                        <div className="flex-1 grid md:grid-cols-2 gap-8">
                          <div className="space-y-4">
                            {proposal.slides[currentSlide-1].points?.map((p, i) => (
                              <div key={i} className="bg-slate-50 p-6 rounded-[24px] border-2 border-transparent hover:border-emerald-200 transition-all flex items-start gap-4 shadow-sm">
                                <div className="bg-emerald-500 w-2 h-2 rounded-full mt-2 shrink-0" />
                                <p className="font-bold text-slate-700 leading-relaxed">{p}</p>
                              </div>
                            ))}
                          </div>
                          <div className="flex flex-col justify-end">
                             <div className="bg-gradient-to-br from-emerald-500 to-emerald-700 p-8 rounded-[40px] text-white shadow-xl relative overflow-hidden">
                                <Lightbulb className="absolute top-[-10px] right-[-10px] w-32 h-32 opacity-10 rotate-12" />
                                <p className="text-xs font-black text-emerald-200 uppercase tracking-widest mb-3">Speee Insight</p>
                                <p className="text-xl font-bold leading-relaxed italic">
                                  "{proposal.slides[currentSlide-1].insight}"
                                </p>
                             </div>
                          </div>
                        </div>
                      </div>
                    )
                  )}
                </div>
                
                <div className="bg-slate-50 p-6 border-t border-slate-100 flex justify-between items-center px-12">
                   <div className="flex gap-4">
                      <div className="flex items-center gap-2">
                        <div className="w-3 h-3 bg-emerald-500 rounded-full"></div>
                        <span className="text-xs font-black text-slate-400 uppercase tracking-widest">Ieul Partner</span>
                      </div>
                   </div>
                   <div className="flex gap-2">
                    <button onClick={() => setCurrentSlide(s => Math.max(0, s-1))} className="bg-white p-3 rounded-2xl shadow-sm hover:shadow-md transition-all active:scale-90"><ChevronLeft/></button>
                    <button onClick={() => setCurrentSlide(s => Math.min(proposal?.slides?.length || 0, s+1))} className="bg-white p-3 rounded-2xl shadow-sm hover:shadow-md transition-all active:scale-90"><ChevronRight/></button>
                   </div>
                </div>
              </div>
            </div>
          </div>
        ) : (
          <div className="grid lg:grid-cols-2 gap-12 items-center py-12">
            <div className="space-y-8 text-center lg:text-left">
              <h2 className="text-6xl font-black text-slate-900 leading-[1.1]">
                受託を、<br/>
                <span className="text-emerald-500 italic">科学</span>する。<br/>
                <span className="text-yellow-500 underline decoration-8">爆速</span>で。
              </h2>
              <p className="text-xl text-slate-500 font-medium leading-relaxed">
                日本最大級の不動産一括査定サイト「イエウール」。<br/>
                AI分析、トーン調整✨、ブラッシュアップ✨機能を備え、<br/>
                刺さる提案資料を1クリックで作成。
              </p>
              <div className="flex flex-wrap gap-4 justify-center lg:justify-start">
                <div className="flex items-center gap-2 bg-white px-4 py-2 rounded-full shadow-sm border border-slate-100">
                  <CheckCircle2 className="text-emerald-500 w-5 h-5" />
                  <span className="font-bold text-sm">企業リサーチ自動化</span>
                </div>
                <div className="flex items-center gap-2 bg-white px-4 py-2 rounded-full shadow-sm border border-slate-100">
                  <CheckCircle2 className="text-emerald-500 w-5 h-5" />
                  <span className="font-bold text-sm">スライド構成自動生成</span>
                </div>
                <div className="flex items-center gap-2 bg-white px-4 py-2 rounded-full shadow-sm border border-slate-100">
                  <CheckCircle2 className="text-emerald-500 w-5 h-5" />
                  <span className="font-bold text-sm">メール文面作成</span>
                </div>
              </div>
            </div>
            <div className="relative hidden lg:block">
              <div className="absolute inset-0 bg-emerald-200 blur-[100px] opacity-20"></div>
              <div className="bg-white rounded-[60px] p-8 shadow-2xl rotate-2 border border-slate-100">
                 <div className="bg-slate-50 aspect-video rounded-[40px] flex flex-col items-center justify-center border-4 border-white shadow-inner gap-4">
                    <Presentation className="w-20 h-20 text-slate-200" />
                    <p className="text-slate-300 font-black tracking-tighter">PREVIEW CANVAS</p>
                 </div>
              </div>
              <div className="absolute -bottom-4 -left-4 bg-emerald-500 text-white p-6 rounded-3xl shadow-xl flex items-center gap-4 -rotate-3">
                 <Rocket className="w-8 h-8" />
                 <div>
                    <p className="font-black text-lg leading-none">AI Powered</p>
                    <p className="text-xs text-emerald-100 mt-1 font-bold">Fast & Accurate</p>
                 </div>
              </div>
            </div>
          </div>
        )}
      </div>

      {showEmailModal && (
        <div className="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4 backdrop-blur-sm">
          <div className="bg-white rounded-[40px] w-full max-w-2xl overflow-hidden flex flex-col max-h-[80vh] shadow-2xl border-4 border-white">
            <div className="p-8 border-b border-slate-100 flex justify-between items-center">
              <h3 className="text-2xl font-black text-slate-800 flex items-center gap-2">
                <Mail className="text-emerald-500" />
                フォローアップメール ✨
              </h3>
              <button onClick={() => setShowEmailModal(false)} className="text-slate-400 hover:text-slate-600 font-bold p-2 hover:bg-slate-50 rounded-full transition-all">閉じる</button>
            </div>
            <div className="p-8 flex-1 overflow-y-auto">
              {!emailDraft ? (
                <div className="flex flex-col items-center justify-center py-12">
                  <Loader2 className="animate-spin text-emerald-500 w-8 h-8 mb-4" />
                  <p className="font-bold text-slate-500">最適なメール文面を考えています...</p>
                </div>
              ) : (
                <pre className="whitespace-pre-wrap font-sans text-slate-600 bg-slate-50 p-6 rounded-3xl text-sm leading-relaxed border border-slate-100">
                  {emailDraft}
                </pre>
              )}
            </div>
            {emailDraft && (
              <div className="p-8 bg-slate-50 flex justify-end">
                <button 
                  onClick={() => copyToClipboard(emailDraft)}
                  className="bg-emerald-500 text-white px-8 py-3 rounded-2xl font-black flex items-center gap-2 hover:bg-emerald-600 transition-all active:scale-95 shadow-lg shadow-emerald-100"
                >
                  <Copy className="w-4 h-4" />
                  内容をコピー
                </button>
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  );
}
